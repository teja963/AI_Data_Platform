  "sql_solution": "SELECT COUNT(DISTINCT customer_id) count FROM orders WHERE amount > 200;",
  "pyspark_solution": "from pyspark.sql.functions import *\n\nresult = orders.filter(col(\"amount\") > 200).agg(countDistinct(\"customer_id\").alias(\"count\"))"
