  "description": "Find customers who placed more than one order on the same day.",
  "tables": {
    "orders": [
      {
        "customer_id": 1,
        "date": "2024-01-01"
      },
      {
        "customer_id": 1,
        "date": "2024-01-01"
      },
      {
        "customer_id": 2,
        "date": "2024-01-02"
      },
      {
        "customer_id": 3,
        "date": "2024-01-03"
      },
      {
